# 本番用環境変数の雛形。コピーして値を埋める:
#   cp .env.production.example .env.production
# .env.production は絶対にコミットしないこと(.gitignore済み)。

# --- 必須 -------------------------------------------------------------------
# credentials復号キー(config/master.key の内容)。未設定だと起動しない。
RAILS_MASTER_KEY=

# このサーバーに到達するホスト名(カンマ区切り)。未設定だと起動しない。
FHIR_ALLOWED_HOSTS=fhir.example.com

# DBパスワード(docker-compose.prod.yml の db サービスと共有)
FHIR_SERVER_DATABASE_PASSWORD=

# --- 認証(本番はデフォルト有効。無効化は起動エラーになる) -----------------
FHIR_AUTH_ENABLED=true

# --- 任意 -------------------------------------------------------------------
# Sentryエラーモニタリング(未設定なら無効)
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# B2B連携先のIP/CIDR許可リスト(未設定なら制限なし)
# FHIR_IP_ALLOWLIST=203.0.113.0/24,198.51.100.7

# レート制限の調整(デフォルト: 10/分, 30/5分, 300/分, 120/分)
# FHIR_RATE_TOKEN_IP=10
# FHIR_RATE_TOKEN_CLIENT=30
# FHIR_RATE_API_TOKEN=300
# FHIR_RATE_API_IP=120

# 認証失敗ban(デフォルト: 10回で300秒)
# FHIR_AUTH_FAIL_MAX=10
# FHIR_AUTH_FAIL_BANTIME=300

# リクエストボディ上限バイト数(デフォルト10MB)
# FHIR_MAX_BODY_BYTES=10485760

# 期限切れトークンの保持日数(rake fhir:purge_expired、デフォルト30日)
# FHIR_TOKEN_RETENTION_DAYS=30

# Bulk Data $export の調整(rake fhir:purge_bulk_exports で掃除)
# BULK_EXPORT_MAX_FILE_BYTES=10485760    # 1ファイルの上限(超過で自動分割、既定10MB)
# BULK_EXPORT_MAX_TOTAL_BYTES=52428800   # エクスポート全体の上限(超過で失敗、既定50MB)
# BULK_EXPORT_STALE_MINUTES=60           # このハートビート間隔を超えたin_progressはfailedにする
# BULK_EXPORT_RETENTION_DAYS=3           # 完了/失敗/キャンセル済みジョブの保持日数

# Pumaワーカー数(デフォルト2。rack-attackカウンタはワーカー毎に独立する点に注意)
# WEB_CONCURRENCY=2
